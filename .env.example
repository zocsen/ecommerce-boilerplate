# ===========================================
# Agency E-Commerce Boilerplate — Environment
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Barion Payment Gateway
BARION_POS_KEY=your-barion-pos-key
BARION_ENVIRONMENT=test

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_MARKETING_FROM_EMAIL=marketing@yourdomain.com

# Invoicing (choose one: billingo | szamlazz | none)
INVOICING_PROVIDER=none
BILLINGO_API_KEY=
SZAMLAZZ_AGENT_KEY=

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret (for abandoned cart job)
CRON_SECRET=your-cron-secret
