# ===========================================
# Agency E-Commerce Boilerplate — Environment
# ===========================================
#
# ENV FILE LOADING ORDER (Next.js):
#   next dev   → .env.local overrides .env  (use local Supabase)
#   next build → .env only                  (use remote Supabase)
#   next start → .env only                  (use remote Supabase)
#
# For local development, copy this file to .env.local and fill in
# local Supabase values (from `supabase status`).
#
# Modern Supabase CLI uses new-format keys:
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
#
# Legacy JWT keys (eyJhbGci...) also work but are deprecated.
# Run `supabase status` to get the correct keys for your local instance.

# --- Remote Supabase (production / build) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Barion Payment Gateway
BARION_POS_KEY=your-barion-pos-key
BARION_ENVIRONMENT=test

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_MARKETING_FROM_EMAIL=marketing@yourdomain.com
# Optional: for development, redirect all emails to yourself
RESEND_TEST_RECIPIENT=
# Optional: webhook signing secret (for production webhook validation)
RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# Invoicing (choose one: billingo | szamlazz | none)
INVOICING_PROVIDER=none
BILLINGO_API_KEY=
SZAMLAZZ_AGENT_KEY=

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret (for abandoned cart job)
CRON_SECRET=your-cron-secret

# Newsletter unsubscribe link signing key (any long random string)
UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# Abandoned cart Edge Function env vars (set in Supabase dashboard → Edge Functions → Secrets)
# ENABLE_ABANDONED_CART mirrors site.config features.enableAbandonedCart
ENABLE_ABANDONED_CART=true
# SITE_URL is the public URL the Edge Function uses to call /api/email/abandoned-cart
SITE_URL=https://your-domain.com
