# ===========================================
# Agency E-Commerce Boilerplate — Environment
# ===========================================
#
# ENV FILE LOADING ORDER (Next.js):
#   next dev   → .env.local overrides .env  (use local Supabase)
#   next build → .env only                  (use remote Supabase)
#   next start → .env only                  (use remote Supabase)
#
# For local development, copy this file to .env.local and fill in
# local Supabase values (from `supabase status`). The well-known
# local keys are pre-filled in .env.local.example below:
#
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role

# --- Remote Supabase (production / build) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Barion Payment Gateway
BARION_POS_KEY=your-barion-pos-key
BARION_ENVIRONMENT=test

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_MARKETING_FROM_EMAIL=marketing@yourdomain.com

# Invoicing (choose one: billingo | szamlazz | none)
INVOICING_PROVIDER=none
BILLINGO_API_KEY=
SZAMLAZZ_AGENT_KEY=

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret (for abandoned cart job)
CRON_SECRET=your-cron-secret
